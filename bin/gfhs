#!/bin/bash

set -u

fail() {
  echo "Erro: $1" >&2
  exit 1
}

if ! command -v git >/dev/null 2>&1; then
  fail "Git não está instalado no ambiente."
fi

if ! command -v git-flow >/dev/null 2>&1; then
  fail "git-flow não está instalado. Instale-o e tente novamente."
fi

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || fail "Este diretório não é um repositório Git."

if ! git diff --quiet || ! git diff --cached --quiet; then
  fail "Há mudanças não commitadas. Faça commit/stash antes de iniciar o hotfix."
fi

if [ "$(git config --get gitflow.initialized 2>/dev/null || true)" != "true" ]; then
  fail "git flow não está inicializado (execute 'git flow init')."
fi

BASE_BRANCH=$(git config --get gitflow.branch.hotfix.startpoint 2>/dev/null || true)
if [ -z "$BASE_BRANCH" ]; then
  BASE_BRANCH="main"
fi

git checkout "$BASE_BRANCH" || fail "Não foi possível mudar para a branch $BASE_BRANCH."

echo "Buscando tags do origin..."
git fetch --tags || fail "Falha ao buscar tags do origin."

LAST_TAG=$(git tag -l | grep -E '^v?[0-9]+\.[0-9]+\.[0-9]+$' | sort -V | tail -n1)

if [ -z "$LAST_TAG" ]; then
  echo "Nenhuma tag encontrada. Iniciando com a versão 1.0.0"
  NEXT_VERSION="1.0.0"
else
  echo "Última versão encontrada: $LAST_TAG"

  CLEAN_TAG=${LAST_TAG#v}

  IFS='.' read -r -a VERSION_PARTS <<<"$CLEAN_TAG"
  PATCH=$((VERSION_PARTS[2] + 1))
  NEXT_VERSION="${VERSION_PARTS[0]}.${VERSION_PARTS[1]}.$PATCH"
fi

echo "Versão sugerida para o Hotfix: $NEXT_VERSION"

HOTFIX_BRANCH="hotfix/$NEXT_VERSION"

if git show-ref --verify --quiet "refs/heads/$HOTFIX_BRANCH"; then
  echo "A branch $HOTFIX_BRANCH já existe localmente. Execução interrompida."
  exit 1
fi

if git ls-remote --exit-code --heads origin "$HOTFIX_BRANCH" >/dev/null 2>&1; then
  echo "A branch $HOTFIX_BRANCH já existe no origin. Execução interrompida."
  exit 1
fi

if ! git flow hotfix start "$NEXT_VERSION"; then
  fail "Falha ao iniciar hotfix com git flow."
fi

echo "Publicando branch no origin..."
if ! git push -u origin "$HOTFIX_BRANCH"; then
  fail "Falha ao publicar a branch $HOTFIX_BRANCH no origin."
fi

echo "Pronto! Você está na branch $HOTFIX_BRANCH"
